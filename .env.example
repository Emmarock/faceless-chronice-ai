# Faceless Chronicle AI — backend env template.
# Copy to .env (gitignored) and fill in real values. Source it with
# `set -a; source .env; set +a` before running the Spring Boot app, or
# wire it into your IDE run configuration's "Environment variables" field.
#
# Every value below corresponds to a ${VAR:default} reference in
# application.yaml / application-dev.yaml. Empty defaults mean the feature
# is disabled until you provide a value.

# -------- Database --------
SPRING_DATASOURCE_PASSWORD=

# -------- AI providers --------
OPENAI_KEY=
PEXELS_KEY=
ELEVENLABS_KEY=
FAL_KEY=
GOOGLE_TTS_KEY=

# -------- AI Tutor Twin (HeyGen avatar/voice + lesson scripts) --------
# HeyGen trains the avatar + cloned voice and renders the lesson videos
# (HEYGEN_API_KEY). The spoken lesson script is written by the configured
# lesson provider:
#   LESSON_PROVIDER=openai  (default) -> reuses OPENAI_KEY above
#   LESSON_PROVIDER=claude            -> uses ANTHROPIC_API_KEY (claude-opus-4-8)
# Leave the relevant keys blank to keep the AI-tutor feature dormant
# (endpoints return a clean "not configured" error). HEYGEN_DEFAULT_VOICE_ID
# is an optional fallback voice for accounts where voice cloning is unavailable.
LESSON_PROVIDER=openai
ANTHROPIC_API_KEY=
HEYGEN_API_KEY=
HEYGEN_DEFAULT_VOICE_ID=453c20e1525a429080e2ad9e4b26f2cd

# -------- Social OAuth (server-side credentials) --------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Instagram Business publishing reuses the Facebook App above — no separate
# credentials needed. The Instagram OAuth surface is the same Facebook
# authorize dialog with IG-specific scopes.

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn Developer Portal → Apps → Auth tab. The OAuth flow uses
# authorization_code grant with scopes "openid profile email w_member_social".
# Leave blank in dev to disable the LinkedIn connect flow.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -------- AWS / S3 (real AWS only — leave empty for local MinIO) --------
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=eu-west-2
AWS_S3_BUCKET=faceless-chronicle-ai
AWS_ENDPOINT_URL=